@* ── MODAL GALERÍA ── *@
<div id="modalGaleria" class="fixed inset-0 bg-black/80 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl max-w-4xl w-full max-h-[90vh] overflow-auto relative">
        @* Header del Modal *@
        <div class="sticky top-0 bg-white border-b border-gray-100 px-6 py-5 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-black text-gray-900">Galería de Fotos</h2>
                <p id="galeria-contador" class="text-[11px] text-gray-500 font-bold uppercase tracking-wider mt-1">Cargando...</p>
            </div>
            <button onclick="cerrarGaleria()" type="button" class="w-10 h-10 bg-gray-100 hover:bg-gray-200 rounded-full flex items-center justify-center transition-colors">
                <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Contenido del Modal *@
        <div class="p-6">
            <div class="relative bg-gray-100 rounded-2xl overflow-hidden h-96 md:h-[500px] flex items-center justify-center">
                @* Loader *@
                <div id="galeria-loader" class="absolute inset-0 bg-black/40 z-20 flex items-center justify-center hidden">
                    <span class="w-12 h-12 border-4 border-white/30 border-t-white rounded-full animate-spin"></span>
                </div>
                
                @* Imagen *@
                <img id="galeria-img" src="" alt="Galería" class="w-full h-full object-cover transition-opacity duration-300 opacity-0" />

                @* Botón Anterior *@
                <button type="button" id="btnGaleriaAnterior" onclick="cargarImagenGaleria(indiceGaleriaActual - 1)" 
                        class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-black/50 hover:bg-[#E31E24] text-white transition-colors flex items-center justify-center z-10">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>

                @* Botón Siguiente *@
                <button type="button" id="btnGaleriaSiguiente" onclick="cargarImagenGaleria(indiceGaleriaActual + 1)" 
                        class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-black/50 hover:bg-[#E31E24] text-white transition-colors flex items-center justify-center z-10">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>

            @* Descripción *@
            <div class="mt-6">
                <p class="text-[11px] font-black uppercase tracking-wider text-gray-500 mb-2" id="galeria-tipo">Local</p>
                <p id="galeria-desc" class="text-gray-700 text-sm leading-relaxed">Descubre el ambiente de nuestro restaurante.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let indiceGaleriaActual = 0;
        let totalImagenes = 0;

        function abrirGaleria() {
            document.getElementById('modalGaleria').classList.remove('hidden');
            cargarImagenGaleria(0);
        }

        function cerrarGaleria() {
            document.getElementById('modalGaleria').classList.add('hidden');
        }

        function cargarImagenGaleria(index) {
            $('#galeria-loader').removeClass('hidden');

            $.ajax({
                url: '@Url.Action("ObtenerImagenesGaleria", "Home")',
                type: 'GET',
                data: { index: index },
                success: function (data) {
                    if (!data || data.total === 0 || !data.imagen) {
                        $('#galeria-loader').addClass('hidden');
                        $('#galeria-img').attr('src', '').removeClass('opacity-100').addClass('opacity-0');
                        $('#galeria-desc').text('No hay imágenes activas en la galería.');
                        $('#galeria-tipo').text('Sin contenido');
                        $('#galeria-contador').text('0 / 0');
                        totalImagenes = 0;
                        return;
                    }

                    totalImagenes = data.total;
                    indiceGaleriaActual = data.actual;

                    $('#galeria-img').removeClass('opacity-100').addClass('opacity-0');

                    setTimeout(function () {
                        $('#galeria-img').attr('src', data.imagen.urlImagen);
                        $('#galeria-desc').text(data.imagen.descripcion);
                        $('#galeria-tipo').text(data.imagen.tipo);
                        $('#galeria-contador').text((data.actual + 1) + ' / ' + data.total);

                        $('#galeria-img').off('load').on('load', function () {
                            $('#galeria-loader').addClass('hidden');
                            $('#galeria-img').removeClass('opacity-0').addClass('opacity-100');
                        });

                        // Si la imagen ya estaba en cache, mostrarla inmediatamente
                        if ($('#galeria-img')[0].complete) {
                            $('#galeria-loader').addClass('hidden');
                            $('#galeria-img').removeClass('opacity-0').addClass('opacity-100');
                        }
                    }, 100);
                },
                error: function () {
                    $('#galeria-loader').addClass('hidden');
                    console.error('Error al cargar la imagen');
                }
            });
        }

        // Cerrar modal al pulsar ESC
        $(document).on('keydown', function (e) {
            if (e.key === 'Escape') {
                cerrarGaleria();
            }
        });

        // Cerrar modal al hacer click fuera
        $('#modalGaleria').on('click', function (e) {
            if (this === e.target) {
                cerrarGaleria();
            }
        });
    </script>
}


