@{
    ViewData["Title"] = "Inicio";
    var stats = Model;
}

@* ── HERO ── *@
<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 min-h-[540px] flex items-center">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-[#E31E24] rounded-full opacity-[0.04] blur-3xl -translate-x-1/4 translate-y-1/4 pointer-events-none"></div>
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image:radial-gradient(circle,#fff 1px,transparent 1px);background-size:28px 28px;"></div>

    <div class="relative z-10 px-8 md:px-16 py-16 w-full">
        <div class="max-w-2xl">
            <span class="inline-flex items-center gap-2 bg-[#E31E24]/15 border border-[#E31E24]/25 text-[#E31E24] px-4 py-1.5 rounded-full text-[11px] font-black uppercase tracking-widest mb-6">
                <span class="w-1.5 h-1.5 bg-[#E31E24] rounded-full animate-pulse"></span>
                Pedidos Online Disponibles
            </span>
            <h1 class="text-5xl md:text-[5.5rem] font-black text-white leading-[0.9] mb-6 tracking-tight">
                Sabor real<br/>
                <span class="text-[#E31E24]">cada día.</span>
            </h1>
            <p class="text-gray-400 text-lg md:text-xl mb-10 leading-relaxed max-w-lg">
                Pide tu comida favorita desde casa. Menú artesanal, ingredientes frescos y entrega rápida directamente a tu puerta.
            </p>
            <div class="flex flex-wrap gap-4">
                @if (User.Identity!.IsAuthenticated)
                {
                    <a asp-controller="Menu" asp-action="RealizarPedido"
                       class="inline-flex items-center gap-2 bg-[#E31E24] text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest border-2 border-transparent hover:border-white transition-all shadow-2xl shadow-red-900/40">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        Hacer Pedido
                    </a>
                    <a asp-controller="Menu" asp-action="Index"
                       class="inline-flex items-center gap-2 bg-white/10 text-white border border-white/15 px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-white/20 transition-all backdrop-blur-sm">
                        Ver la Carta
                    </a>
                }
                else
                {
                    <a asp-controller="Acceso" asp-action="Register"
                       class="inline-flex items-center gap-2 bg-[#E31E24] text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest border-2 border-transparent hover:border-white transition-all shadow-2xl shadow-red-900/40">
                        Empezar Ahora — Es Gratis
                    </a>
                    <a asp-controller="Menu" asp-action="Index"
                       class="inline-flex items-center gap-2 bg-white/10 text-white border border-white/15 px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-white/20 transition-all backdrop-blur-sm">
                        Ver la Carta
                    </a>
                }
            </div>
        </div>
    </div>

    @* Stat badges flotantes *@
    <div class="absolute right-8 top-1/2 -translate-y-1/2 hidden lg:flex flex-col gap-3">
        <div class="bg-white/8 backdrop-blur-md border border-white/10 rounded-2xl px-6 py-4 text-white text-center">
            <div class="text-2xl font-black text-[#E31E24]">@stats.ValoracionMedia★</div>
            <div class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider">Valoración</div>
        </div>
        <div class="bg-white/8 backdrop-blur-md border border-white/10 rounded-2xl px-6 py-4 text-white text-center">
            <div class="text-2xl font-black">@stats.TiempoEntrega'</div>
            <div class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider">Entrega</div>
        </div>
        <div class="bg-white/8 backdrop-blur-md border border-white/10 rounded-2xl px-6 py-4 text-white text-center">
            <div class="text-2xl font-black">@stats.TotalPedidos+</div>
            <div class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider">Pedidos</div>
        </div>
    </div>
</section>

@* ── STATS BAR ── *@
<section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
    <div class="bg-white rounded-2xl p-6 text-center border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-3xl font-black text-[#E31E24] mb-1">@stats.TiempoEntrega'</div>
        <div class="text-[11px] text-gray-400 uppercase tracking-wider font-bold">Entrega promedio</div>
    </div>
    <div class="bg-white rounded-2xl p-6 text-center border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-3xl font-black text-gray-900 mb-1">@stats.TotalProductos+</div>
        <div class="text-[11px] text-gray-400 uppercase tracking-wider font-bold">Platos disponibles</div>
    </div>
    <div class="bg-white rounded-2xl p-6 text-center border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-3xl font-black text-gray-900 mb-1">@stats.ValoracionMedia★</div>
        <div class="text-[11px] text-gray-400 uppercase tracking-wider font-bold">Valoración media</div>
    </div>
    <div class="bg-white rounded-2xl p-6 text-center border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-3xl font-black text-gray-900 mb-1">@stats.TotalPedidos+</div>
        <div class="text-[11px] text-gray-400 uppercase tracking-wider font-bold">Pedidos realizados</div>
    </div>
</section>

@* ── SERVICIOS ── *@
<section class="mb-12">
    <div class="text-center mb-10">
        <p class="text-[11px] font-black uppercase tracking-widest text-[#E31E24] mb-2">Lo que ofrecemos</p>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900">Todo en un lugar</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

        @* Carta Online *@
        <a asp-controller="Menu" asp-action="Index"
           class="group block bg-white rounded-2xl p-7 border-2 border-gray-100 hover:border-[#E31E24] hover:shadow-xl transition-all">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#E31E24] transition-colors">
                <svg class="w-6 h-6 text-[#E31E24] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
            </div>
            <h3 class="font-black text-gray-900 text-xl mb-2">Carta Online</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">Explora todos nuestros platos con imágenes, descripciones y precios actualizados al momento.</p>
            <span class="inline-flex items-center gap-1 text-[#E31E24] text-xs font-black uppercase tracking-wider">Ver carta <span class="group-hover:translate-x-1 transition-transform inline-block">→</span></span>
        </a>

        @* Pedidos Online *@
        <a asp-controller="Menu" asp-action="RealizarPedido"
           class="group block bg-white rounded-2xl p-7 border-2 border-gray-100 hover:border-[#E31E24] hover:shadow-xl transition-all">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#E31E24] transition-colors">
                <svg class="w-6 h-6 text-[#E31E24] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
            </div>
            <h3 class="font-black text-gray-900 text-xl mb-2">Pedidos Online</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">Carrito inteligente, cupones de descuento y seguimiento del estado de tu pedido en tiempo real.</p>
            <span class="inline-flex items-center gap-1 text-[#E31E24] text-xs font-black uppercase tracking-wider">Hacer pedido <span class="group-hover:translate-x-1 transition-transform inline-block">→</span></span>
        </a>

        @* Reservas - Activo *@
        <a asp-controller="Reservas" asp-action="Index"
           class="group block bg-white rounded-2xl p-7 border-2 border-gray-100 hover:border-[#E31E24] hover:shadow-xl transition-all relative overflow-hidden">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#E31E24] transition-colors">
                <svg class="w-6 h-6 text-[#E31E24] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
            <h3 class="font-black text-gray-900 text-xl mb-2">Reserva de Mesa</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">Cruza nuestras puertas. Reserva tu mesa en tiempo real para la ocasión perfecta. Elige fecha, turno y comensales.</p>
            <span class="inline-flex items-center gap-1 text-[#E31E24] text-xs font-black uppercase tracking-wider">Ver Mesas Libres <span class="group-hover:translate-x-1 transition-transform inline-block">→</span></span>
        </a>

        @* Cupones *@
        <div onclick="mostrarCupones()" class="cursor-pointer bg-gradient-to-br from-[#E31E24] to-[#b01519] rounded-2xl p-7 text-white relative overflow-hidden">
            <div class="absolute -bottom-6 -right-6 w-28 h-28 bg-white/10 rounded-full pointer-events-none"></div>
            <div class="absolute -top-5 -left-5 w-20 h-20 bg-black/10 rounded-full pointer-events-none"></div>
            <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-5 relative">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                </svg>
            </div>
            <h3 class="font-black text-white text-xl mb-2 relative">Cupones y Ofertas</h3>
            <p class="text-red-100 text-sm leading-relaxed mb-5 relative">Descuentos exclusivos para clientes registrados. Aplícalos al checkout y ahorra al instante.</p>
            <span class="inline-block bg-white/20 border border-white/20 text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full relative">¡Ahorra hasta 20%!</span>
        </div>

        @* Valoraciones *@
        <a asp-controller="Valoraciones" asp-action="Index"
           class="group block bg-gray-900 rounded-2xl p-7 text-white relative overflow-hidden hover:shadow-xl transition-all">
            <div class="absolute -bottom-6 -right-6 w-28 h-28 bg-white/5 rounded-full pointer-events-none"></div>
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-5 relative group-hover:bg-[#E31E24] transition-colors">
                <svg class="w-6 h-6 text-yellow-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
            </div>
            <h3 class="font-black text-white text-xl mb-2 relative">Opiniones Reales</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-5 relative">Lee las experiencias de nuestros clientes y comparte la tuya tras cada pedido verificado.</p>
            <div class="flex items-center gap-2 relative">
                <div class="flex gap-0.5">
                    @for (int i = 0; i < 5; i++)
                    {
                        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                    }
                </div>
                <span class="text-gray-400 text-xs font-bold">@stats.ValoracionMedia de 5 · @stats.TotalValoraciones+ valoraciones</span>
            </div>
        </a>

        @* Galería de Fotos *@
        <button onclick="abrirGaleria()" type="button" class="w-full text-left bg-white rounded-2xl p-7 border-2 border-gray-100 hover:border-[#E31E24] hover:shadow-xl transition-all cursor-pointer group">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#E31E24] transition-colors">
                <svg class="w-6 h-6 text-[#E31E24] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
            <h3 class="font-black text-gray-900 text-xl mb-2">Galería</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">Explora el ambiente y ambiente de nuestro restaurante a través de nuestras fotos.</p>
            <span class="inline-flex items-center gap-1 text-[#E31E24] text-xs font-black uppercase tracking-wider">Ver galería <span class="group-hover:translate-x-1 transition-transform inline-block">→</span></span>
        </button>
    </div>
</section>

@* ── INFO STRIP ── *@
