@model IEnumerable<ProyectoRestauranteC_.Models.Cupon>

@{ ViewData["Title"] = "Gesti¾n de Cupones"; }

<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 py-16">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="relative z-10 px-8 md:px-16">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-4xl font-black text-white mb-2">Gesti¾n de Cupones</h1>
                <p class="text-gray-400">@Model.Count() cupones disponibles</p>
            </div>
            <button type="button" onclick="abrirModalCupon()" class="bg-[#E31E24] text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-black transition-all shadow-lg">
                + Nuevo Cup¾n
            </button>
        </div>
    </div>
</section>

<section class="bg-white rounded-2xl border-2 border-gray-100 overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b">
            <tr>
                <th class="px-6 py-3 text-left font-black">C¾digo</th>
                <th class="px-6 py-3 text-left font-black">Tipo</th>
                <th class="px-6 py-3 text-left font-black">Valor</th>
                <th class="px-6 py-3 text-left font-black">Vßlido Hasta</th>
                <th class="px-6 py-3 text-left font-black">Usos</th>
                <th class="px-6 py-3 text-left font-black">Estado</th>
                <th class="px-6 py-3 text-center font-black">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y">
            @foreach(var c in Model)
            {
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-3 font-black tracking-widest">@c.Codigo</td>
                    <td class="px-6 py-3"><span class="@(c.TipoDescuento == "Porcentaje" ? "bg-blue-100 text-blue-700" : "bg-green-100 text-green-700") px-2 py-1 rounded text-xs font-bold">@(c.TipoDescuento == "Porcentaje" ? "%" : "Ć")</span></td>
                    <td class="px-6 py-3 font-bold">@(c.TipoDescuento == "Porcentaje" ? c.ValorDescuento + "%" : c.ValorDescuento.ToString("C"))</td>
                    <td class="px-6 py-3">@c.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td class="px-6 py-3">@c.VecesUsado/@c.UsoMaximo</td>
                    <td class="px-6 py-3">
                        <span class="@(c.Activo ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700") px-2 py-1 rounded text-xs font-bold">
                            @(c.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>
                    <td class="px-6 py-3 text-center flex gap-2 justify-center">
                        <button type="button" onclick="abrirModalCupon(@c.Id, '@c.Codigo', '@c.TipoDescuento', @c.ValorDescuento.ToString().Replace(",", "."), '@c.FechaInicio.ToString("yyyy-MM-dd")', '@c.FechaFin.ToString("yyyy-MM-dd")', @c.UsoMaximo, @(c.Activo ? "true" : "false"))" class="bg-blue-100 text-blue-600 px-3 py-1 rounded hover:bg-blue-200 text-xs font-bold">
                            Editar
                        </button>
                        <button type="button" onclick="eliminarCupon(@c.Id)" class="bg-red-100 text-red-600 px-3 py-1 rounded hover:bg-red-200 text-xs font-bold">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@* MODAL CUPėN *@
<div id="modalCupon" class="fixed inset-0 bg-black/80 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl w-full max-w-md p-6">
        <h2 class="text-2xl font-black text-gray-900 mb-4" id="modalCuponTitle">Nuevo Cup¾n</h2>
        <form id="formCupon">
            <input type="hidden" id="cuponId" value="0">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">C¾digo</label>
                    <input type="text" id="cuponCodigo" class="w-full px-4 py-2 border border-gray-300 rounded-lg" maxlength="50" required>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Tipo</label>
                        <select id="cuponTipo" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                            <option value="Porcentaje">Porcentaje (%)</option>
                            <option value="Fijo">Fijo (Ć)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Valor</label>
                        <input type="number" id="cuponValor" class="w-full px-4 py-2 border border-gray-300 rounded-lg" step="0.01" required>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Fecha Inicio</label>
                        <input type="date" id="cuponFechaInicio" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Fecha Fin</label>
                        <input type="date" id="cuponFechaFin" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Uso Mßximo</label>
                    <input type="number" id="cuponUsoMaximo" class="w-full px-4 py-2 border border-gray-300 rounded-lg" min="1" required>
                </div>
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="cuponActivo" class="w-4 h-4" checked>
                    <label for="cuponActivo" class="text-sm font-bold text-gray-700">Activo</label>
                </div>
            </div>
            <div class="flex gap-3 mt-6">
                <button type="submit" class="flex-1 bg-[#E31E24] text-white px-4 py-2 rounded-lg font-bold hover:bg-black transition">
                    Guardar
                </button>
                <button type="button" onclick="cerrarModalCupon()" class="flex-1 bg-gray-200 text-gray-900 px-4 py-2 rounded-lg font-bold hover:bg-gray-300 transition">
                    Cancelar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mt-8 text-center">
    <a asp-controller="Admin" asp-action="Index" class="text-[#E31E24] font-black">Volver al Panel</a>
</div>

<script>
function abrirModalCupon(id = 0, codigo = '', tipo = 'Porcentaje', valor = 0, fechaInicio = '', fechaFin = '', usoMaximo = 1, activo = true) {
    document.getElementById('cuponId').value = id;
    document.getElementById('cuponCodigo').value = codigo;
    document.getElementById('cuponTipo').value = tipo;
    document.getElementById('cuponValor').value = valor;
    document.getElementById('cuponFechaInicio').value = fechaInicio;
    document.getElementById('cuponFechaFin').value = fechaFin;
    document.getElementById('cuponUsoMaximo').value = usoMaximo;
    document.getElementById('cuponActivo').checked = activo;
    document.getElementById('modalCuponTitle').textContent = id === 0 ? 'Nuevo Cup¾n' : 'Editar Cup¾n';
    document.getElementById('modalCupon').classList.remove('hidden');
}

function cerrarModalCupon() {
    document.getElementById('modalCupon').classList.add('hidden');
    document.getElementById('formCupon').reset();
}

document.getElementById('formCupon').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('cuponId').value;
    const codigo = document.getElementById('cuponCodigo').value;
    const tipo = document.getElementById('cuponTipo').value;
    const valor = document.getElementById('cuponValor').value;
    const fechaInicio = document.getElementById('cuponFechaInicio').value;
    const fechaFin = document.getElementById('cuponFechaFin').value;
    const usoMaximo = document.getElementById('cuponUsoMaximo').value;
    const activo = document.getElementById('cuponActivo').checked;

    const endpoint = id == 0 ? '/Admin/CreateCupon' : '/Admin/UpdateCupon';
    const params = new URLSearchParams();
    if (id != 0) params.append('id', id);
    params.append('codigo', codigo);
    params.append('tipoDescuento', tipo);
    params.append('valorDescuento', valor);
    params.append('fechaInicio', new Date(fechaInicio).toISOString());
    params.append('fechaFin', new Date(fechaFin).toISOString());
    params.append('usoMaximo', usoMaximo);
    params.append('activo', activo);

    try {
        const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params
        });
        const data = await response.json();
        Swal.fire({
            title: data.success ? '╔xito' : 'Error',
            text: data.message,
            icon: data.success ? 'success' : 'error',
            timer: 5000,
            timerProgressBar: true,
            didClose: () => {
                if (data.success) location.reload();
            }
        });
    } catch (error) {
        Swal.fire({
            title: 'Error',
            text: 'Error: ' + error,
            icon: 'error',
            timer: 5000,
            timerProgressBar: true
        });
    }
});

document.getElementById('modalCupon').addEventListener('click', (e) => {
    if (e.target === document.getElementById('modalCupon')) cerrarModalCupon();
});

function eliminarCupon(id) {
    Swal.fire({
        title: '┐Deseas eliminar este cup¾n?',
        text: 'Esta acci¾n no se puede deshacer',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#E31E24',
        cancelButtonColor: '#6B7280',
        confirmButtonText: 'SĒ, eliminar',
        cancelButtonText: 'Cancelar'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch('/Admin/DeleteCupon', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id
            }).then(r => r.json()).then(d => {
                Swal.fire({
                    title: d.success ? '╔xito' : 'Error',
                    text: d.message,
                    icon: d.success ? 'success' : 'error',
                    timer: 5000,
                    timerProgressBar: true,
                    didClose: () => {
                        if (d.success) location.reload();
                    }
                });
            });
        }
    });
}
</script>
