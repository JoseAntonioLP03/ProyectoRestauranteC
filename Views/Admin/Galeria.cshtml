@model IEnumerable<ProyectoRestauranteC_.Models.Galeria>

@{ ViewData["Title"] = "Gestiůn de GalerŪa"; }

<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 py-16">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="relative z-10 px-8 md:px-16">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-4xl font-black text-white mb-2">Gestiůn de GalerŪa</h1>
                <p class="text-gray-400">@Model.Count() imŠgenes</p>
            </div>
            <button type="button" onclick="abrirModalGaleria()" class="bg-[#E31E24] text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-black transition-all shadow-lg">
                + Nueva Imagen
            </button>
        </div>
    </div>
</section>

<section class="bg-white rounded-2xl border-2 border-gray-100 overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b">
            <tr>
                <th class="px-6 py-3 text-left font-black">ID</th>
                <th class="px-6 py-3 text-left font-black">URL</th>
                <th class="px-6 py-3 text-left font-black">Descripciůn</th>
                <th class="px-6 py-3 text-left font-black">Tipo</th>
                <th class="px-6 py-3 text-left font-black">Estado</th>
                <th class="px-6 py-3 text-center font-black">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y">
            @foreach(var img in Model.OrderByDescending(x => x.Id))
            {
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-3">@img.Id</td>
                    <td class="px-6 py-3 max-w-xs truncate"><small>@img.UrlImagen</small></td>
                    <td class="px-6 py-3 max-w-xs truncate">@img.Descripcion</td>
                    <td class="px-6 py-3">@img.Tipo</td>
                    <td class="px-6 py-3">
                        <span class="@(img.Activa ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-700") px-2 py-1 rounded text-xs font-bold">
                            @(img.Activa ? "Activa" : "Inactiva")
                        </span>
                    </td>
                    <td class="px-6 py-3 text-center flex gap-2 justify-center">
                        <button type="button" onclick="abrirModalGaleria(@img.Id, '@img.UrlImagen', '@img.Descripcion', '@img.Tipo', @(img.Activa ? "true" : "false"))" class="bg-blue-100 text-blue-600 px-3 py-1 rounded hover:bg-blue-200 text-xs font-bold">
                            Editar
                        </button>
                        <button type="button" onclick="eliminarGaleria(@img.Id)" class="bg-red-100 text-red-600 px-3 py-1 rounded hover:bg-red-200 text-xs font-bold">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@* MODAL GALERÕA *@
<div id="modalGaleria" class="fixed inset-0 bg-black/80 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl w-full max-w-md p-6">
        <h2 class="text-2xl font-black text-gray-900 mb-4" id="modalGaleriaTitle">Nueva Imagen</h2>
        <form id="formGaleria">
            <input type="hidden" id="galeriaId" value="0">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">URL Imagen</label>
                    <input type="text" id="galeriaUrl" class="w-full px-4 py-2 border border-gray-300 rounded-lg" maxlength="255" required>
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Descripciůn</label>
                    <textarea id="galeriaDescripcion" class="w-full px-4 py-2 border border-gray-300 rounded-lg" rows="2"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Tipo</label>
                    <select id="galeriaTipo" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                        <option value="Local">Local</option>
                        <option value="Plato">Plato</option>
                    </select>
                </div>
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="galeriaActiva" class="w-4 h-4" checked>
                    <label for="galeriaActiva" class="text-sm font-bold text-gray-700">Activa</label>
                </div>
            </div>
            <div class="flex gap-3 mt-6">
                <button type="submit" class="flex-1 bg-[#E31E24] text-white px-4 py-2 rounded-lg font-bold hover:bg-black transition">
                    Guardar
                </button>
                <button type="button" onclick="cerrarModalGaleria()" class="flex-1 bg-gray-200 text-gray-900 px-4 py-2 rounded-lg font-bold hover:bg-gray-300 transition">
                    Cancelar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mt-8 text-center">
    <a asp-controller="Admin" asp-action="Index" class="text-[#E31E24] font-black">Volver al Panel</a>
</div>

<script>
function abrirModalGaleria(id = 0, url = '', descripcion = '', tipo = 'Local', activa = true) {
    document.getElementById('galeriaId').value = id;
    document.getElementById('galeriaUrl').value = url;
    document.getElementById('galeriaDescripcion').value = descripcion;
    document.getElementById('galeriaTipo').value = tipo;
    document.getElementById('galeriaActiva').checked = activa;
    document.getElementById('modalGaleriaTitle').textContent = id === 0 ? 'Nueva Imagen' : 'Editar Imagen';
    document.getElementById('modalGaleria').classList.remove('hidden');
}

function cerrarModalGaleria() {
    document.getElementById('modalGaleria').classList.add('hidden');
    document.getElementById('formGaleria').reset();
}

document.getElementById('formGaleria').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('galeriaId').value;
    const url = document.getElementById('galeriaUrl').value;
    const descripcion = document.getElementById('galeriaDescripcion').value;
    const tipo = document.getElementById('galeriaTipo').value;
    const activa = document.getElementById('galeriaActiva').checked;

    const endpoint = id == 0 ? '/Admin/CreateGaleria' : '/Admin/UpdateGaleria';
    const params = new URLSearchParams();
    if (id != 0) params.append('id', id);
    params.append('urlImagen', url);
    params.append('descripcion', descripcion);
    params.append('tipo', tipo);
    params.append('activa', activa);

    try {
        const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params
        });
        const data = await response.json();
        Swal.fire({
            title: data.success ? '…xito' : 'Error',
            text: data.message,
            icon: data.success ? 'success' : 'error',
            timer: 5000,
            timerProgressBar: true,
            didClose: () => {
                if (data.success) location.reload();
            }
        });
    } catch (error) {
        Swal.fire({
            title: 'Error',
            text: 'Error: ' + error,
            icon: 'error',
            timer: 5000,
            timerProgressBar: true
        });
    }
});

document.getElementById('modalGaleria').addEventListener('click', (e) => {
    if (e.target === document.getElementById('modalGaleria')) cerrarModalGaleria();
});

function eliminarGaleria(id) {
    Swal.fire({
        title: 'ŅDeseas eliminar esta imagen?',
        text: 'Esta acciůn no se puede deshacer',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#E31E24',
        cancelButtonColor: '#6B7280',
        confirmButtonText: 'SŪ, eliminar',
        cancelButtonText: 'Cancelar'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch('/Admin/DeleteGaleria', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id
            }).then(r => r.json()).then(d => {
                Swal.fire({
                    title: d.success ? '…xito' : 'Error',
                    text: d.message,
                    icon: d.success ? 'success' : 'error',
                    timer: 5000,
                    timerProgressBar: true,
                    didClose: () => {
                        if (d.success) location.reload();
                    }
                });
            });
        }
    });
}
</script>
