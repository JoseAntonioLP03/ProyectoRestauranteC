@{
    ViewData["Title"] = "Panel de Administración";
    var stats = Model;
}

@* ?? HEADER ?? *@
<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 py-16">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-[#E31E24] rounded-full opacity-[0.04] blur-3xl -translate-x-1/4 translate-y-1/4 pointer-events-none"></div>

    <div class="relative z-10 px-8 md:px-16">
        <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-3">Panel de Administración</h1>
        <p class="text-gray-400 text-lg max-w-lg">Gestiona todos los datos de tu restaurante desde aquí</p>
    </div>
</section>



@* ?? TODAS LAS TABLAS ?? *@
<section class="mb-12">
    <h2 class="text-3xl font-black text-gray-900 mb-8">Tablas de la Base de Datos</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        @* Productos *@
        <a asp-controller="Admin" asp-action="Productos"
           class="group block bg-white rounded-2xl p-7 border-2 border-gray-100 hover:border-[#E31E24] hover:shadow-xl transition-all">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-[#E31E24] transition-colors">
                <svg class="w-6 h-6 text-[#E31E24] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                </svg>
            </div>
            <h3 class="font-black text-gray-900 mb-1">Productos</h3>
            <p class="text-gray-500 text-xs uppercase tracking-wider font-bold mb-4">@stats.TotalProductos registros</p>
            <span class="inline-flex items-center gap-1 text-[#E31E24] text-xs font-black uppercase tracking-wider">Gestionar</span>
        </a>

        @* Categorías *@
