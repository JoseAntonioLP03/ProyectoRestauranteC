            <h3 class="font-black text-gray-900 mb-1">Galería</h3>
            <p class="text-gray-500 text-xs uppercase tracking-wider font-bold mb-4">Imágenes</p>
            <span class="inline-flex items-center gap-1 text-[#E31E24] text-xs font-black uppercase tracking-wider">Gestionar</span>
