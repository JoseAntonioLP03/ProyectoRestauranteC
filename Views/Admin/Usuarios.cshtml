@model IEnumerable<ProyectoRestauranteC_.Models.Usuario>

@{ ViewData["Title"] = "Gestión de Usuarios"; }

<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 py-16">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="relative z-10 px-8 md:px-16">
        <h1 class="text-4xl font-black text-white mb-2">Gestión de Usuarios</h1>
        <p class="text-gray-400">@Model.Count() usuarios registrados</p>
    </div>
</section>

<section class="bg-white rounded-2xl border-2 border-gray-100 overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b">
            <tr>
                <th class="px-6 py-3 text-left font-black">ID</th>
                <th class="px-6 py-3 text-left font-black">Nombre</th>
                <th class="px-6 py-3 text-left font-black">Email</th>
                <th class="px-6 py-3 text-left font-black">Rol</th>
                <th class="px-6 py-3 text-left font-black">Estado</th>
                <th class="px-6 py-3 text-center font-black">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y">
            @foreach(var u in Model)
            {
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-3">@u.Id</td>
                    <td class="px-6 py-3 font-bold">@u.Nombre</td>
                    <td class="px-6 py-3">@u.Email</td>
                    <td class="px-6 py-3"><span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs font-bold">@u.Rol</span></td>
                    <td class="px-6 py-3">
                        <span class="@(u.Activo ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700") px-2 py-1 rounded text-xs font-bold">
                            @(u.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>
                    <td class="px-6 py-3 text-center flex gap-2 justify-center">
                        <button type="button" onclick="abrirModalUsuario(@u.Id, @(u.Activo ? "true" : "false"))" class="bg-blue-100 text-blue-600 px-3 py-1 rounded hover:bg-blue-200 text-xs font-bold">
                            @(u.Activo ? "Desactivar" : "Activar")
                        </button>
                        <button type="button" onclick="eliminarUsuario(@u.Id)" class="bg-red-100 text-red-600 px-3 py-1 rounded hover:bg-red-200 text-xs font-bold">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@* MODAL USUARIO *@
<div id="modalUsuario" class="fixed inset-0 bg-black/80 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl w-full max-w-md p-6">
        <h2 class="text-2xl font-black text-gray-900 mb-4">Cambiar Estado del Usuario</h2>
        <form id="formUsuario">
            <input type="hidden" id="usuarioId" value="0">
            <div class="space-y-4">
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="usuarioActivo" class="w-4 h-4">
                    <label for="usuarioActivo" class="text-sm font-bold text-gray-700">Activo</label>
                </div>
            </div>
            <div class="flex gap-3 mt-6">
                <button type="submit" class="flex-1 bg-[#E31E24] text-white px-4 py-2 rounded-lg font-bold hover:bg-black transition">
                    Guardar
                </button>
                <button type="button" onclick="cerrarModalUsuario()" class="flex-1 bg-gray-200 text-gray-900 px-4 py-2 rounded-lg font-bold hover:bg-gray-300 transition">
                    Cancelar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mt-8 text-center">
    <a asp-controller="Admin" asp-action="Index" class="text-[#E31E24] font-black">Volver al Panel</a>
</div>

<script>
function abrirModalUsuario(id, activo) {
    document.getElementById('usuarioId').value = id;
    document.getElementById('usuarioActivo').checked = activo;
    document.getElementById('modalUsuario').classList.remove('hidden');
}

function cerrarModalUsuario() {
    document.getElementById('modalUsuario').classList.add('hidden');
}

document.getElementById('formUsuario').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('usuarioId').value;
    const activo = document.getElementById('usuarioActivo').checked;

    const params = new URLSearchParams();
    params.append('id', id);
    params.append('activo', activo);

    try {
        const response = await fetch('/Admin/UpdateUsuario', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params
        });
        const data = await response.json();
        Swal.fire({
            title: data.success ? 'Éxito' : 'Error',
            text: data.message,
            icon: data.success ? 'success' : 'error',
            timer: 5000,
            timerProgressBar: true,
            didClose: () => {
                if (data.success) location.reload();
            }
        });
    } catch (error) {
        Swal.fire({
            title: 'Error',
            text: 'Error: ' + error,
            icon: 'error',
            timer: 5000,
            timerProgressBar: true
        });
    }
});

document.getElementById('modalUsuario').addEventListener('click', (e) => {
    if (e.target === document.getElementById('modalUsuario')) cerrarModalUsuario();
});

function eliminarUsuario(id) {
    Swal.fire({
        title: 'żDeseas eliminar este usuario?',
        text: 'Esta acción no se puede deshacer',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#E31E24',
        cancelButtonColor: '#6B7280',
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch('/Admin/DeleteUsuario', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id
            }).then(r => r.json()).then(d => {
                Swal.fire({
                    title: d.success ? 'Éxito' : 'Error',
                    text: d.message,
                    icon: d.success ? 'success' : 'error',
                    timer: 5000,
                    timerProgressBar: true,
                    didClose: () => {
                        if (d.success) location.reload();
                    }
                });
            });
        }
    });
}
</script>
