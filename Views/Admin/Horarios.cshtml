@model IEnumerable<ProyectoRestauranteC_.Models.Horario>

@{ ViewData["Title"] = "Gestión de Horarios"; }

<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 py-16">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="relative z-10 px-8 md:px-16">
        <h1 class="text-4xl font-black text-white mb-2">Gestión de Horarios</h1>
        <p class="text-gray-400">Configuración semanal</p>
    </div>
</section>

<section class="bg-white rounded-2xl border-2 border-gray-100 overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b">
            <tr>
                <th class="px-6 py-3 text-left font-black">ID</th>
                <th class="px-6 py-3 text-left font-black">Día</th>
                <th class="px-6 py-3 text-left font-black">Apertura</th>
                <th class="px-6 py-3 text-left font-black">Cierre</th>
                <th class="px-6 py-3 text-left font-black">Estado</th>
                <th class="px-6 py-3 text-center font-black">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y">
            @{
                string[] dias = { "Domingo", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado" };
            }
            @foreach(var h in Model.OrderBy(x => x.DiaSemana))
            {
                var aperturaStr = h.HoraApertura.Hours.ToString("D2") + ":" + h.HoraApertura.Minutes.ToString("D2");
                var cierreStr = h.HoraCierre.Hours.ToString("D2") + ":" + h.HoraCierre.Minutes.ToString("D2");
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-3">@h.Id</td>
                    <td class="px-6 py-3 font-bold">@dias[h.DiaSemana >= 0 && h.DiaSemana < dias.Length ? h.DiaSemana : 0]</td>
                    <td class="px-6 py-3">@aperturaStr</td>
                    <td class="px-6 py-3">@cierreStr</td>
                    <td class="px-6 py-3">
                        <span class="@(h.Activo ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700") px-2 py-1 rounded text-xs font-bold">
                            @(h.Activo ? "Abierto" : "Cerrado")
                        </span>
                    </td>
                    <td class="px-6 py-3 text-center">
                        <button type="button" onclick="abrirModalHorario(@h.Id, '@aperturaStr', '@cierreStr', @(h.Activo ? "true" : "false"))" class="bg-blue-100 text-blue-600 px-3 py-1 rounded hover:bg-blue-200 text-xs font-bold">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@* MODAL HORARIO *@
<div id="modalHorario" class="fixed inset-0 bg-black/80 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl w-full max-w-md p-6">
        <h2 class="text-2xl font-black text-gray-900 mb-4">Editar Horario</h2>
        <form id="formHorario">
            <input type="hidden" id="horarioId" value="0">
            <div class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Apertura</label>
                        <input type="time" id="horarioApertura" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Cierre</label>
                        <input type="time" id="horarioCierre" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="horarioActivo" class="w-4 h-4">
                    <label for="horarioActivo" class="text-sm font-bold text-gray-700">Abierto</label>
                </div>
            </div>
            <div class="flex gap-3 mt-6">
                <button type="submit" class="flex-1 bg-[#E31E24] text-white px-4 py-2 rounded-lg font-bold hover:bg-black transition">
                    Guardar
                </button>
                <button type="button" onclick="cerrarModalHorario()" class="flex-1 bg-gray-200 text-gray-900 px-4 py-2 rounded-lg font-bold hover:bg-gray-300 transition">
                    Cancelar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mt-8 text-center">
    <a asp-controller="Admin" asp-action="Index" class="text-[#E31E24] font-black">Volver al Panel</a>
</div>

<script>
function abrirModalHorario(id, apertura, cierre, activo) {
    document.getElementById('horarioId').value = id;
    document.getElementById('horarioApertura').value = apertura;
    document.getElementById('horarioCierre').value = cierre;
    document.getElementById('horarioActivo').checked = activo;
    document.getElementById('modalHorario').classList.remove('hidden');
}

function cerrarModalHorario() {
    document.getElementById('modalHorario').classList.add('hidden');
}

document.getElementById('formHorario').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('horarioId').value;
    const apertura = document.getElementById('horarioApertura').value;
    const cierre = document.getElementById('horarioCierre').value;
    const activo = document.getElementById('horarioActivo').checked;

    const params = new URLSearchParams();
    params.append('id', id);
    params.append('horaApertura', apertura);
    params.append('horaCierre', cierre);
    params.append('activo', activo);

    try {
        const response = await fetch('/Admin/UpdateHorario', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params
        });
        const data = await response.json();
        Swal.fire({
            title: data.success ? 'Éxito' : 'Error',
            text: data.message,
            icon: data.success ? 'success' : 'error',
            timer: 5000,
            timerProgressBar: true,
            didClose: () => {
                if (data.success) location.reload();
            }
        });
    } catch (error) {
        Swal.fire({
            title: 'Error',
            text: 'Error: ' + error,
            icon: 'error',
            timer: 5000,
            timerProgressBar: true
        });
    }
});

document.getElementById('modalHorario').addEventListener('click', (e) => {
    if (e.target === document.getElementById('modalHorario')) cerrarModalHorario();
});
</script>