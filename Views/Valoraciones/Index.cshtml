@model IEnumerable<ProyectoRestauranteC_.Models.Valoracion>

@{
    ViewData["Title"] = "Valoraciones";
}

@* ?? HEADER ?? *@
<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 py-16">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-[#E31E24] rounded-full opacity-[0.04] blur-3xl -translate-x-1/4 translate-y-1/4 pointer-events-none"></div>

    <div class="relative z-10 px-8 md:px-16 flex items-center justify-between">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-3">Opiniones de Clientes</h1>
            <p class="text-gray-400 text-lg max-w-lg">Lee las experiencias reales de nuestros clientes y comparte la tuya</p>
        </div>
        
        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Valoraciones" asp-action="Crear"
               class="inline-flex items-center gap-2 bg-[#E31E24] text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest border-2 border-transparent hover:border-white transition-all shadow-2xl shadow-red-900/40 whitespace-nowrap">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Dejar Valoración
            </a>
        }
        else
        {
            <a asp-controller="Acceso" asp-action="Login"
               class="inline-flex items-center gap-2 bg-gray-400 text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest cursor-not-allowed opacity-60 whitespace-nowrap">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Dejar Valoración
            </a>
        }
    </div>
</section>

@* ?? VALORACIONES ?? *@
<section>
    @if (Model.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var valoracion in Model)
            {
                <div class="bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-[#E31E24] hover:shadow-xl transition-all">
                    @* Header con usuario y estrellas *@
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex-1">
                            <h3 class="font-black text-gray-900">@valoracion.Usuario.Nombre</h3>
                            <p class="text-[11px] text-gray-500 font-bold uppercase tracking-wider">@valoracion.Fecha.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="flex gap-0.5">
                            @for (int i = 0; i < 5; i++)
                            {
                                @if (i < valoracion.Puntuacion)
                                {
                                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                }
                            }
                        </div>
                    </div>

                    @* Comentario *@
                    <p class="text-gray-700 text-sm leading-relaxed line-clamp-4">@valoracion.Comentario</p>

                    @* Badge de calificación *@
                    <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
                        <span class="inline-flex items-center gap-1 bg-yellow-50 text-yellow-700 px-3 py-1.5 rounded-full text-[11px] font-bold uppercase tracking-wider">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            @valoracion.Puntuacion.0 de 5
                        </span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl p-12 border-2 border-gray-100 text-center">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v12a2 2 0 01-2 2l-4 4z"/>
            </svg>
            <h3 class="text-xl font-black text-gray-900 mb-2">No hay valoraciones aún</h3>
            <p class="text-gray-500 text-sm mb-6">Sé el primero en dejar tu opinión sobre nuestro restaurante</p>
            @if (User.Identity!.IsAuthenticated)
            {
                <a asp-controller="Valoraciones" asp-action="Crear"
                   class="inline-flex items-center gap-2 bg-[#E31E24] text-white px-6 py-3 rounded-lg font-black text-xs uppercase tracking-widest hover:bg-black transition-all">
                    Dejar Valoración
                </a>
            }
        </div>
    }
</section>
