@{
    ViewData["Title"] = "Dejar Valoración";
}

@* ?? HEADER ?? *@
<section class="relative bg-gradient-to-br from-[#0d0d0d] via-[#1a0000] to-[#111] rounded-3xl overflow-hidden mb-12 py-16">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E31E24] rounded-full opacity-[0.07] blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-[#E31E24] rounded-full opacity-[0.04] blur-3xl -translate-x-1/4 translate-y-1/4 pointer-events-none"></div>

    <div class="relative z-10 px-8 md:px-16">
        <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-3">Dejar una Valoración</h1>
        <p class="text-gray-400 text-lg max-w-lg">Tu opinión nos ayuda a mejorar. Comparte tu experiencia</p>
    </div>
</section>

@* ?? FORMULARIO ?? *@
<section class="max-w-2xl mx-auto">
    <div class="bg-white rounded-2xl border-2 border-gray-100 p-8">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            @* Calificación por Estrellas *@
            <div class="mb-8">
                <label class="block text-sm font-black uppercase tracking-widest text-gray-700 mb-4">żCuántas estrellas nos das?</label>
                <input type="hidden" id="calificacionHidden" name="calificacion" value="" />
                <div class="flex gap-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <button type="button" class="rating-btn w-14 h-14 rounded-lg border-2 border-gray-300 font-black text-lg transition-all hover:border-[#E31E24] hover:bg-red-50" data-value="@i">
                            @i
                        </button>
                    }
                </div>
            </div>

            @* Comentario *@
            <div class="mb-8">
                <label for="comentario" class="block text-sm font-black uppercase tracking-widest text-gray-700 mb-3">Tu comentario</label>
                <textarea id="comentario" name="comentario" rows="6" 
                          class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-[#E31E24] focus:ring-0 resize-none font-medium text-gray-900 placeholder-gray-400"
                          placeholder="Cuéntanos tu experiencia... (máximo 500 caracteres)"
                          required></textarea>
                <p id="charCount" class="text-[11px] text-gray-500 font-bold uppercase tracking-wider mt-2">0 / 500 caracteres</p>
            </div>

            @* Botones *@
            <div class="flex gap-3 pt-6 border-t border-gray-100">
                <a asp-controller="Valoraciones" asp-action="Index"
                   class="flex-1 px-6 py-3 bg-gray-100 text-gray-900 rounded-xl font-black text-sm uppercase tracking-widest hover:bg-gray-200 transition-colors text-center">
                    Cancelar
                </a>
                <button type="submit" class="flex-1 px-6 py-3 bg-[#E31E24] text-white rounded-xl font-black text-sm uppercase tracking-widest hover:bg-black transition-all shadow-lg shadow-red-900/30">
                    Enviar Valoración
                </button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        // Contador de caracteres
        document.getElementById('comentario').addEventListener('input', function () {
            const count = this.value.length;
            document.getElementById('charCount').textContent = count + ' / 500 caracteres';
        });

        // Sistema de calificación por botones
        const ratingBtns = document.querySelectorAll('.rating-btn');
        const calificacionHidden = document.getElementById('calificacionHidden');

        ratingBtns.forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                
                // Remover clase active de todos
                ratingBtns.forEach(b => {
                    b.classList.remove('bg-[#E31E24]', 'text-white', 'border-[#E31E24]');
                    b.classList.add('border-gray-300', 'text-gray-700');
                });
                
                // Agregar clase active al clickeado
                this.classList.remove('border-gray-300', 'text-gray-700');
                this.classList.add('bg-[#E31E24]', 'text-white', 'border-[#E31E24]');
                
                // Guardar valor en el hidden input
                calificacionHidden.value = this.dataset.value;
            });
        });

        // Envío AJAX del formulario
        document.querySelector('form').addEventListener('submit', function (e) {
            e.preventDefault();

            const calificacion = calificacionHidden.value;
            const comentario = document.getElementById('comentario').value.trim();

            // Validaciones
            if (!calificacion) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Advertencia',
                    text: 'Por favor, selecciona una calificación',
                    confirmButtonColor: '#E31E24'
                });
                return;
            }

            if (!comentario || comentario.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Advertencia',
                    text: 'Por favor, escribe un comentario',
                    confirmButtonColor: '#E31E24'
                });
                return;
            }

            if (comentario.length > 500) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Advertencia',
                    text: 'El comentario no puede exceder 500 caracteres',
                    confirmButtonColor: '#E31E24'
                });
                return;
            }

            // Mostrar loader
            Swal.fire({
                icon: 'info',
                title: 'Enviando valoración...',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // Envío AJAX
            $.ajax({
                url: '@Url.Action("Crear", "Valoraciones")',
                type: 'POST',
                data: {
                    calificacion: parseInt(calificacion),
                    comentario: comentario,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (data) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ˇValoración enviada!',
                        text: 'Gracias por tu opinión. Tu valoración ha sido registrada.',
                        confirmButtonColor: '#E31E24',
                        confirmButtonText: 'Ver valoraciones',
                        timer: 2000,
                        timerProgressBar: true
                    }).then((result) => {
                        window.location.href = '@Url.Action("Index", "Valoraciones")';
                    });
                },
                error: function (error) {
                    let mensaje = 'Ha ocurrido un error al enviar tu valoración';
                    
                    if (error.responseJSON && error.responseJSON.message) {
                        mensaje = error.responseJSON.message;
                    } else if (error.statusText) {
                        mensaje = error.statusText;
                    }

                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: mensaje,
                        confirmButtonColor: '#E31E24'
                    });
                }
            });
        });
    </script>
}
