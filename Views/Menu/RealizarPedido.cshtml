@model IEnumerable<ProyectoRestauranteC_.Models.Categoria>

@using ProyectoRestauranteC_.Models
@{
    ViewData["Title"] = "Realizar Pedido";
    var carrito = ViewBag.Carrito as List<ItemCarrito> ?? new List<ItemCarrito>();
    decimal envio = 3.00m;
    decimal tarifas = 2.05m;
    decimal subtotalCarrito = carrito.Sum(i => i.Subtotal);
    decimal totalCarrito = subtotalCarrito + envio + tarifas;
}

<div class="bg-white min-h-screen">

    <div class="container mx-auto px-4 pb-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            @* COLUMNA IZQUIERDA: MENÚ (2/3 del ancho) *@
            <div class="lg:col-span-2">
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    @* Grid de categorías en dos columnas *@
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        @foreach (var categoria in Model)
                        {
                            <div class="space-y-3">
                                @* Título de categoría con línea roja *@
                                <div class="pb-2 mb-4 border-b-2 border-[#E31E24]">
                                    <h2 class="text-lg font-bold text-gray-900">@categoria.Nombre</h2>
                                </div>

                                @* Lista de productos *@
                                <div class="space-y-2">
                                    @foreach (var producto in categoria.Productos.Where(p => p.Disponible))
                                    {
                                        <div class="border-2 border-gray-200 rounded-lg p-3 hover:border-[#E31E24] transition-colors cursor-pointer">
                                            <div class="flex justify-between items-start gap-3">
                                                <div class="flex-1 min-w-0">
                                                    <h3 class="text-sm font-semibold text-gray-900 mb-1">
                                                        @producto.Nombre
                                                    </h3>
                                                    @if (!string.IsNullOrEmpty(producto.Descripcion))
                                                    {
                                                        <p class="text-xs text-gray-500 line-clamp-1">@producto.Descripcion</p>
                                                    }
                                                </div>
                                                <div class="flex items-center gap-2 flex-shrink-0">
                                                    <span class="text-sm font-bold text-gray-900 whitespace-nowrap">
                                                        @producto.Precio€
                                                    </span>
                                    <form asp-action="AgregarAlCarrito" method="post">
                                        <input type="hidden" name="id" value="@producto.Id" />
                                        <input type="hidden" name="nombre" value="@producto.Nombre" />
                                        <input type="hidden" name="precio" value="@producto.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                        <button type="submit" class="bg-[#E31E24] text-white rounded-full w-6 h-6 flex items-center justify-center hover:bg-black transition-colors">
                                            <span class="text-sm font-bold">+</span>
                                        </button>
                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>



            @* COLUMNA DERECHA: RESUMEN DEL PEDIDO (1/3 del ancho) *@
            <div class="lg:col-span-1">
                <div class="bg-white rounded-lg border-2 border-[#E31E24] p-6 sticky top-24">
                    @* Header de la cesta *@
                    <div class="pb-4 mb-6 border-b border-gray-200">
                        <div class="flex items-center justify-between">
                            <div>
                                <h2 class="text-xl font-bold text-gray-900">Tu Cesta</h2>
                                <p class="text-xs text-gray-500 mt-1">Productos seleccionados</p>
                            </div>
                            @if (carrito.Any())
                            {
                                <form asp-action="VaciarCarrito" method="post">
                                    <button type="submit" class="text-xs text-red-600 hover:text-red-800 font-semibold underline transition-colors">
                                        Vaciar cesta
                                    </button>
                                </form>
                            }
                        </div>
                    </div>

                    @* Productos en el carrito con scroll *@
                    <div class="mb-6 max-h-[350px] overflow-y-auto">
                        @if (!carrito.Any())
                        {
                            <div class="text-center py-8">
                                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                                </svg>
                                <p class="text-sm text-gray-400">Tu cesta está vacía</p>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-3 pr-2">
                                @foreach (var item in carrito)
                                {
                                    <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-lg border border-gray-200">
                                        <div class="flex-1 min-w-0">
                                            <h4 class="text-sm font-semibold text-gray-900">@item.Nombre</h4>
                                            <p class="text-xs text-gray-500 mt-1">@item.Precio€ × @item.Cantidad</p>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-bold text-[#E31E24]">@item.Subtotal€</span>
                                            <form asp-action="EliminarDelCarrito" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="bg-gray-200 text-gray-700 rounded-full w-6 h-6 flex items-center justify-center hover:bg-red-500 hover:text-white transition-colors">
                                                    <span class="text-sm font-bold">-</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* Resumen de precios *@
                    <div class="space-y-3 pt-4 border-t border-gray-200">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Productos</span>
                            <span class="font-semibold text-gray-900">@subtotalCarrito€</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Envío</span>
                            <span class="font-semibold text-gray-900">3,00€</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Tarifas</span>
                            <span class="font-semibold text-gray-900">2,05€</span>
                        </div>
                        
                        @* Total *@
                        <div class="pt-3 border-t border-gray-200">
                            <div class="flex justify-between items-center">
                                <span class="text-base font-bold text-gray-900">Total</span>
                                <span class="text-2xl font-bold text-[#E31E24]">@totalCarrito€</span>
                            </div>
                        </div>
                    </div>

                    @* Botón de pagar *@
                    @if (carrito.Any())
                    {
                        <a asp-action="Checkout" class="block w-full mt-6 bg-[#E31E24] text-white py-3 px-6 rounded-lg font-semibold uppercase text-sm tracking-wide hover:bg-black transition-colors text-center">
                            Pagar y Realizar Pedido
                        </a>
                    }
                    else
                    {
                        <button class="w-full mt-6 bg-[#E31E24] text-white py-3 px-6 rounded-lg font-semibold uppercase text-sm tracking-wide opacity-50 cursor-not-allowed" disabled>
                            Pagar y Realizar Pedido
                        </button>
                    }

                    @* Mensaje de seguridad *@
                    <div class="mt-4 flex items-center justify-center gap-2 text-xs text-gray-500">
                        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                        </svg>
                        <span>Pago seguro con SSL</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* scripts eliminados: carrito gestionado por sesión *@




