@model ProyectoRestauranteC_.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Confirmar Pedido";
    var cuponError = TempData["CuponError"] as string;
}

<div class="bg-[#FBF8F3] min-h-screen py-10">
    <div class="container mx-auto px-4 max-w-5xl">

        <h1 class="text-3xl font-black uppercase tracking-tighter text-black mb-8">
            Confirmar <span class="text-[#E31E24]">Pedido</span>
        </h1>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            @* COLUMNA IZQUIERDA: Datos del usuario + productos *@
            <div class="lg:col-span-2 space-y-6">

                @* Datos del usuario *@
                <div class="bg-white rounded-2xl border border-gray-200 p-6">
                    <h2 class="text-lg font-bold text-gray-900 mb-4 pb-3 border-b-2 border-[#E31E24]">
                        Datos de entrega
                    </h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Nombre</p>
                            <p class="text-sm font-semibold text-gray-900">@Model.Usuario.Nombre</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Email</p>
                            <p class="text-sm font-semibold text-gray-900">@Model.Usuario.Email</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">TelÚfono</p>
                            <p class="text-sm font-semibold text-gray-900">@(Model.Usuario.Telefono ?? "ù")</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Direcci¾n</p>
                            <p class="text-sm font-semibold text-gray-900">@(Model.Usuario.Direccion ?? "ù")</p>
                        </div>
                    </div>
                </div>

                @* Productos del pedido *@
                <div class="bg-white rounded-2xl border border-gray-200 p-6">
                    <h2 class="text-lg font-bold text-gray-900 mb-4 pb-3 border-b-2 border-[#E31E24]">
                        Productos del pedido
                    </h2>
                    <div class="space-y-3">
                        @foreach (var item in Model.Items)
                        {
                            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl border border-gray-200">
                                <div class="flex-1 min-w-0">
                                    <h4 class="text-sm font-semibold text-gray-900">@item.Nombre</h4>
                                    <p class="text-xs text-gray-500 mt-0.5">@item.PrecioÇ Î @item.Cantidad</p>
                                </div>
                                <span class="text-sm font-bold text-[#E31E24] ml-4 whitespace-nowrap">@item.SubtotalÇ</span>
                            </div>
                        }
                    </div>
                </div>

            </div>

            @* COLUMNA DERECHA: Resumen de pago *@
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl border-2 border-[#E31E24] p-6 sticky top-24">
                    <h2 class="text-lg font-bold text-gray-900 mb-4 pb-3 border-b border-gray-200">
                        Resumen de pago
                    </h2>

                    <div class="space-y-3">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Productos</span>
                            <span class="font-semibold text-gray-900">@Model.SubtotalÇ</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">EnvÝo</span>
                            <span class="font-semibold text-gray-900">@Model.EnvioÇ</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Tarifas</span>
                            <span class="font-semibold text-gray-900">@Model.TarifasÇ</span>
                        </div>
                        @if (Model.CuponAplicado != null)
                        {
                            <div class="flex justify-between text-sm text-green-600">
                                <span class="font-semibold">Descuento (@Model.CuponAplicado.Codigo)</span>
                                <span class="font-bold">-@Model.DescuentoÇ</span>
                            </div>
                        }
                        <div class="pt-3 border-t border-gray-200">
                            <div class="flex justify-between items-center">
                                <span class="text-base font-bold text-gray-900">Total</span>
                                <span class="text-2xl font-bold text-[#E31E24]">@Model.TotalÇ</span>
                            </div>
                        </div>
                    </div>

                    @* Secci¾n de cup¾n *@
                    <div class="mt-5 pt-5 border-t border-gray-200">

                        @if (Model.CuponAplicado == null)
                        {
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Cup¾n de descuento</p>
                            <form asp-action="AplicarCupon" method="post" class="space-y-2">
                                <input type="text" name="codigoCupon" placeholder="CËDIGO"
                                       class="w-full border-2 rounded-xl px-3 py-2.5 text-sm uppercase focus:ring-2 focus:ring-[#E31E24] focus:border-[#E31E24] outline-none transition placeholder:text-gray-300 @(cuponError != null ? "border-[#E31E24] bg-red-50" : "border-gray-200")" />
                                @if (cuponError != null)
                                {
                                    <p class="text-xs text-[#E31E24] font-semibold pl-1">? @cuponError</p>
                                }
                                <button type="submit"
                                        class="w-full bg-black text-white text-xs font-black py-2.5 rounded-xl hover:bg-[#E31E24] transition-colors uppercase tracking-widest">
                                    Aplicar cup¾n
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="flex items-center justify-between bg-green-50 border border-green-200 rounded-xl px-4 py-3">
                                <div>
                                    <p class="text-xs font-bold text-green-700 uppercase tracking-widest">Cup¾n aplicado</p>
                                    <p class="text-sm font-black text-green-800">@Model.CuponAplicado.Codigo</p>
                                    <p class="text-xs text-green-600 mt-0.5">
                                        @(Model.CuponAplicado.TipoDescuento == "Porcentaje"
                                            ? $"{Model.CuponAplicado.ValorDescuento}% de descuento"
                                            : $"{Model.CuponAplicado.ValorDescuento}Ç de descuento")
                                    </p>
                                </div>
                                <form asp-action="QuitarCupon" method="post">
                                    <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-bold underline transition-colors">
                                        Quitar
                                    </button>
                                </form>
                            </div>
                        }
                    </div>

                    <form asp-action="ConfirmarPedido" method="post" class="mt-6">
                        <button type="submit" class="w-full bg-[#E31E24] text-white font-black py-4 rounded-xl hover:bg-black transition-all duration-300 uppercase tracking-widest text-sm transform hover:-translate-y-1">
                            Confirmar y Pagar
                        </button>
                    </form>

                    <a asp-action="RealizarPedido" class="block w-full mt-3 text-center text-sm text-gray-500 hover:text-[#E31E24] transition-colors font-semibold">
                        Volver al pedido
                    </a>

                    <div class="mt-4 flex items-center justify-center gap-2 text-xs text-gray-500">
                        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                        </svg>
                        <span>Pago seguro con SSL</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
