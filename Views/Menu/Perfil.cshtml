@model ProyectoRestauranteC_.Models.PerfilViewModel

@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="bg-[#FBF8F3] min-h-screen py-10">
    <div class="container mx-auto px-4 max-w-5xl">

        @* Cabecera *@
        <div class="mb-8">
            <h1 class="text-4xl font-black uppercase tracking-tighter text-black">
                Mi <span class="text-[#E31E24]">Perfil</span>
            </h1>
            <p class="text-gray-500 text-sm font-medium mt-1">Gestiona tus datos y consulta tu historial de pedidos</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            @* COLUMNA IZQUIERDA: Datos del usuario *@
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl border-2 border-[#E31E24] p-6 sticky top-24">

                    @* Avatar *@
                    <div class="flex flex-col items-center mb-6">
                        <div class="w-20 h-20 rounded-full bg-[#E31E24] flex items-center justify-center mb-3 shadow-lg shadow-red-100">
                            <span class="text-3xl font-black text-white uppercase">
                                @Model.Usuario.Nombre.Substring(0, 1)
                            </span>
                        </div>
                        <h2 class="text-lg font-black text-gray-900 uppercase tracking-tight">@Model.Usuario.Nombre</h2>
                        <span class="mt-1 px-3 py-0.5 bg-[#FBF8F3] border border-gray-200 rounded-full text-xs font-black uppercase tracking-widest text-[#E31E24]">
                            @Model.Usuario.Rol
                        </span>
                    </div>

                    @* Datos *@
                    <div class="space-y-4 border-t border-gray-100 pt-5">
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Email</p>
                            <p class="text-sm font-semibold text-gray-900 break-all">@Model.Usuario.Email</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Telķfono</p>
                            <p class="text-sm font-semibold text-gray-900">@(Model.Usuario.Telefono ?? "Ś")</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Direcci¾n</p>
                            <p class="text-sm font-semibold text-gray-900">@(Model.Usuario.Direccion ?? "Ś")</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Miembro desde</p>
                            <p class="text-sm font-semibold text-gray-900">@Model.Usuario.FechaRegistro.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>

                    @* Stats *@
                    <div class="mt-6 pt-5 border-t border-gray-100 grid grid-cols-2 gap-3">
                        <div class="bg-[#FBF8F3] rounded-xl p-3 text-center border border-gray-200">
                            <p class="text-2xl font-black text-[#E31E24]">@Model.Pedidos.Count</p>
                            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mt-0.5">Pedidos</p>
                        </div>
                        <div class="bg-[#FBF8F3] rounded-xl p-3 text-center border border-gray-200">
                            <p class="text-2xl font-black text-[#E31E24]">@Model.Pedidos.Sum(p => p.Total).ToString("0.00")Ć</p>
                            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mt-0.5">Gastado</p>
                        </div>
                    </div>

                    <a asp-controller="Menu" asp-action="RealizarPedido"
                       class="block w-full mt-6 bg-black text-white font-black py-4 rounded-xl hover:bg-[#E31E24] transition-all duration-300 uppercase tracking-widest text-sm text-center transform hover:-translate-y-1">
                        Hacer un pedido
                    </a>
                </div>
            </div>

            @* COLUMNA DERECHA: Historial de pedidos *@
            <div class="lg:col-span-2 space-y-5">

                <h2 class="text-xl font-black uppercase tracking-tight text-black">
                    Historial de <span class="text-[#E31E24]">Pedidos</span>
                </h2>

                @if (!Model.Pedidos.Any())
                {
                    <div class="bg-white rounded-2xl border border-gray-200 p-10 text-center">
                        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                            </svg>
                        </div>
                        <p class="text-gray-500 font-semibold text-sm">A·n no has realizado ning·n pedido</p>
                    </div>
                }
                else
                {
                    @foreach (var pedido in Model.Pedidos)
                    {
                        @* Badge de estado *@
                        var (estadoLabel, estadoClasses) = pedido.Estado switch
                        {
                            "PendientePago" => ("Pendiente de pago", "bg-yellow-50 text-yellow-700 border-yellow-200"),
                            "Confirmado"    => ("Confirmado", "bg-blue-50 text-blue-700 border-blue-200"),
                            "EnCamino"      => ("En camino", "bg-purple-50 text-purple-700 border-purple-200"),
                            "Entregado"     => ("Entregado", "bg-green-50 text-green-700 border-green-200"),
                            "Cancelado"     => ("Cancelado", "bg-red-50 text-red-700 border-red-200"),
                            _               => (pedido.Estado, "bg-gray-50 text-gray-600 border-gray-200")
                        };

                        <div class="bg-white rounded-2xl border border-gray-200 p-5 hover:border-[#E31E24] hover:shadow-sm transition-all duration-200">

                            @* Cabecera del pedido *@
                            <div class="flex items-center justify-between mb-4 pb-4 border-b border-gray-100">
                                <div>
                                    <div class="flex items-center gap-3">
                                        <span class="text-base font-black text-gray-900">#@pedido.Id</span>
                                        <span class="px-2.5 py-0.5 border rounded-full text-xs font-black uppercase tracking-widest @estadoClasses">
                                            @estadoLabel
                                        </span>
                                    </div>
                                    <p class="text-xs text-gray-400 font-medium mt-1">
                                        @pedido.FechaPedido.ToString("dd/MM/yyyy") Ę @pedido.FechaPedido.ToString("HH:mm") Ę @pedido.TipoPedido
                                    </p>
                                </div>
                                <div class="text-right">
                                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Total</p>
                                    <p class="text-xl font-black text-[#E31E24]">@pedido.TotalĆ</p>
                                </div>
                            </div>

                            @* Productos *@
                            <div class="space-y-2">
                                @foreach (var detalle in pedido.Detalles)
                                {
                                    <div class="flex items-center justify-between text-sm">
                                        <div class="flex items-center gap-2">
                                            <span class="w-5 h-5 rounded-full bg-[#FBF8F3] border border-gray-200 flex items-center justify-center text-xs font-black text-[#E31E24]">
                                                @detalle.Cantidad
                                            </span>
                                            <span class="font-semibold text-gray-800">@(detalle.Producto?.Nombre ?? "Producto")</span>
                                        </div>
                                        <span class="font-bold text-gray-700">@((detalle.PrecioUnitario * detalle.Cantidad).ToString("0.00"))Ć</span>
                                    </div>
                                }
                            </div>

                            @* Descuento *@
                            @if (pedido.Descuento > 0)
                            {
                                <div class="mt-3 pt-3 border-t border-dashed border-gray-200 flex justify-between text-xs font-semibold text-green-600">
                                    <span>Descuento aplicado</span>
                                    <span>-@pedido.DescuentoĆ</span>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

        </div>
    </div>
</div>
