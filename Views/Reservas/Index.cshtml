@model List<ProyectoRestauranteC_.Models.Mesa>
@{
    ViewData["Title"] = "Reserva tu Mesa";
}

<div class="h-auto bg-[#FBF8F3] pt-12 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        @* HEADER PAGE *@
        <div class="text-center mb-12">
            <span class="inline-flex items-center gap-2 bg-[#E31E24]/15 border border-[#E31E24]/25 text-[#E31E24] px-4 py-1.5 rounded-full text-[11px] font-black uppercase tracking-widest mb-4">
                <span class="w-1.5 h-1.5 bg-[#E31E24] rounded-full animate-pulse"></span>
                RESERVAS EN TIEMPO REAL
            </span>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight leading-tight">
                Cruza nuestras <br/>
                <span class="text-[#E31E24]">puertas.</span>
            </h1>
            <p class="text-gray-500 mt-4 max-w-lg mx-auto">Selecciona detalles para tu visita. Te asignaremos la mejor mesa para que disfrutes de tu experiencia al mßximo.</p>
        </div>

        @* CONTROLS FORM *@
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 mb-10 max-w-3xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
                <div>
                    <label class="block text-[11px] font-black uppercase tracking-widest text-gray-400 mb-2">Fecha</label>
                    <input type="date" id="fechaReserva" class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-3 font-semibold focus:outline-none focus:border-[#E31E24] focus:ring-1 focus:ring-[#E31E24] transition-all" value="@DateTime.Now.ToString("yyyy-MM-dd")" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label class="block text-[11px] font-black uppercase tracking-widest text-gray-400 mb-2">Hora (Turno)</label>
                    <select id="horaReserva" class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-3 font-semibold focus:outline-none focus:border-[#E31E24] focus:ring-1 focus:ring-[#E31E24] transition-all">
                        <option value="12:30">12:30 (Comida)</option>
                        <option value="14:00">14:00 (Comida)</option>
                        <option value="15:30">15:30 (Comida - ┌ltimo)</option>
                        <option value="20:30">20:30 (Cena)</option>
                        <option value="22:00">22:00 (Cena)</option>
                        <option value="23:30">23:30 (Cena - ┌ltima)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[11px] font-black uppercase tracking-widest text-gray-400 mb-2">Personas</label>
                    <input type="number" id="numPersonas" class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-3 font-semibold focus:outline-none focus:border-[#E31E24] focus:ring-1 focus:ring-[#E31E24] transition-all" value="2" min="1" max="12" />
                </div>
            </div>
            
            <button type="button" id="btnComprobar" class="w-full bg-[#111] hover:bg-[#E31E24] text-white rounded-xl px-6 py-4 mt-8 font-black text-sm uppercase tracking-widest transition-colors shadow-lg flex items-center justify-center gap-2">
                Buscar Disponibilidad
            </button>
        </div>

        @* RESULTADO DISPONIBILIDAD *@
        <div id="resultadoDisponibilidad" class="hidden max-w-xl mx-auto">
            <div class="bg-white rounded-3xl p-8 border-2 border-green-500 shadow-xl shadow-green-100 text-center relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-green-500 rounded-full opacity-[0.05] blur-2xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <h3 class="text-2xl font-black text-gray-900 mb-2">íTenemos hueco para ti!</h3>
                <p class="text-gray-500 mb-8 max-w-sm mx-auto leading-relaxed">Hemos encontrado una mesa perfecta para tu reserva. RevÝsalo y confirma a continuaciˇn.</p>
                
                <div class="bg-gray-50 rounded-2xl p-6 mb-8 text-left grid grid-cols-2 gap-4 border border-gray-100">
                     <div>
                         <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">DÝa asignado</p>
                         <p class="font-bold text-gray-900" id="lblDia">-</p>
                     </div>
                     <div>
                         <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Turno</p>
                         <p class="font-bold text-gray-900" id="lblHora">-</p>
                     </div>
                     <div>
                         <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Comensales</p>
                         <p class="font-bold text-gray-900" id="lblComensales">-</p>
                     </div>
                     <div>
                         <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Zona</p>
                         <p class="font-bold text-gray-900">Salˇn Principal</p>
                     </div>
                </div>

                <input type="hidden" id="hdnMesaId" />
                <button type="button" id="btnConfirmarReserva" class="w-full bg-[#E31E24] hover:bg-red-700 text-white rounded-xl px-6 py-4 font-black text-sm uppercase tracking-widest transition-colors shadow-lg shadow-red-900/30">
                    Confirmar Reserva
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let selectedDate = '';
            let selectedTime = '';
            let selectedPeople = 0;

            $('#btnComprobar').click(function() {
                selectedDate = $('#fechaReserva').val();
                selectedTime = $('#horaReserva').val();
                selectedPeople = $('#numPersonas').val();

                if(!selectedDate || !selectedTime || !selectedPeople) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Faltan datos',
                        text: 'Por favor, completa fecha, hora y comensales.',
                        confirmButtonColor: '#E31E24'
                    });
                    return;
                }

                Swal.showLoading();
                
                $.post('@Url.Action("ComprobarDisponibilidad", "Reservas")', {
                    fecha: selectedDate,
                    hora: selectedTime,
                    npersonas: selectedPeople
                }).done(function(data) {
                    Swal.close();
                    if(data.disponible) {
                        $('#hdnMesaId').val(data.mesaId);
                        
                        // Parse date for display
                        let dateObj = new Date(selectedDate);
                        let formattedDate = dateObj.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                        
                        $('#lblDia').text(formattedDate.charAt(0).toUpperCase() + formattedDate.slice(1));
                        $('#lblHora').text(selectedTime + ' h');
                        $('#lblComensales').text(selectedPeople + (selectedPeople > 1 ? ' Personas' : ' Persona'));
                        
                        $('#resultadoDisponibilidad').removeClass('hidden');
                        
                        // Scroll suave al resultado
                        $('html, body').animate({
                            scrollTop: $("#resultadoDisponibilidad").offset().top - 100
                        }, 500);

                    } else {
                        $('#resultadoDisponibilidad').addClass('hidden');
                        Swal.fire({
                            title: '<span style="font-weight:900;font-size:1.5rem;">Casi lo tienes...</span>',
                            text: 'No disponemos de mesas para ' + selectedPeople + ' personas en ese turno. Por favor, prueba con otra hora u otro dÝa.',
                            icon: 'info',
                            confirmButtonColor: '#111',
                            confirmButtonText: 'Probar otra opciˇn'
                        });
                    }

                }).fail(function() {
                    Swal.close();
                    Swal.fire('Error', 'No se pudo comprobar la disponibilidad. IntÚntelo mßs tarde.', 'error');
                });
            });

            $('#btnConfirmarReserva').click(function() {
                let idMesa = $('#hdnMesaId').val();
                Swal.showLoading();

                $.post('@Url.Action("Reservar", "Reservas")', {
                    idMesa: idMesa,
                    fecha: selectedDate,
                    hora: selectedTime,
                    npersonas: selectedPeople
                }).done(function(res) {
                    if(res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'íReserva Confirmada!',
                            text: 'Te esperamos en TOPMEAL. Tienes todos los detalles en tu perfil.',
                            confirmButtonColor: '#E31E24',
                            allowOutsideClick: false
                        }).then(() => {
                            window.location.href = '@Url.Action("Perfil", "Menu")';
                        });
                    } else {
                        Swal.fire('Error', res.message || 'Error al guardar', 'error');
                    }
                }).fail(function() {
                    Swal.fire('Error', 'Ocurriˇ un error al confirmar tu reserva.', 'error');
                });
            });
        });
    </script>
}