    </h2>
    <p class="text-sm text-gray-400 mb-8">No tienes permisos para acceder a esta secciµn.</p>

    <a asp-controller="Home" asp-action="Index"
       class="w-full block bg-black text-white font-black py-4 rounded-xl hover:bg-[#E31E24] transition-all duration-300 shadow-lg uppercase tracking-widest text-sm transform hover:-translate-y-1">
        Volver al inicio
    </a>

    <p class="text-center text-sm text-gray-400 mt-6">
        ¢Tienes cuenta?
        <a asp-controller="Acceso" asp-action="Login" class="text-[#E31E24] font-black hover:underline ml-1">Inicia sesiµn</a>
    </p>

</div>
